# 1. Ignore EVERYTHING in the root directory first
/*

# 2. Re-include the specific folders and files you want to track
!/vibe_tui/
!/.gitignore
!/README.md
!/pyproject.toml
!/LICENSE
!/architecture.svg
*.swp
# 3. Standard Python ignores (for inside the tracked folders)
__pycache__/
*pycache*
*.py[cod]
*$py.class
!VERIFY.md

# 4. Explicitly ignore virtual environments (even if they were in the root)
env/
.todos/
.sidecar/
.sidecar-agent
.sidecar-task
.sidecar-pr
.sidecar-start.sh
.sidecar-base
.td-root
!/vibe_browser.py
!/example.py
